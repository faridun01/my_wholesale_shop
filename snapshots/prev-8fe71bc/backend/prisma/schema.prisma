// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id               Int       @id @default(autoincrement())
  username         String    @unique
  passwordHash     String    @map("password_hash")
  phone            String?   // Added for password recovery
  role             String    @default("SELLER") // 'ADMIN' | 'MANAGER' | 'SELLER'
  warehouseId      Int?      @map("warehouse_id")
  active           Boolean   @default(true)
  canCancelInvoices Boolean   @default(false) @map("can_cancel_invoices")
  canDeleteData    Boolean   @default(false) @map("can_delete_data")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id])
  invoices     Invoice[]
  payments     Payment[]
  returns      Return[]
  transactions InventoryTransaction[]
  reminders    Reminder[]

  @@map("users")
}

model Warehouse {
  id          Int      @id @default(autoincrement())
  name        String
  address     String?
  city        String?
  note        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users        User[]
  products     Product[]
  batches      ProductBatch[]
  invoices     Invoice[]
  transactions InventoryTransaction[]

  @@map("warehouses")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  products  Product[]

  @@map("categories")
}

model Product {
  id             Int      @id @default(autoincrement())
  categoryId     Int      @map("category_id")
  sku            String?
  name           String
  unit           String
  costPrice      Float    @map("cost_price")
  sellingPrice   Float    @map("selling_price")
  minStock       Float    @default(0) @map("min_stock")
  initialStock   Float    @default(0) @map("initial_stock")
  totalIncoming  Float    @default(0) @map("total_incoming")
  stock          Float    @default(0)
  photoUrl       String?  @map("photo_url")
  active         Boolean  @default(true)
  warehouseId    Int?     @map("warehouse_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  category     Category     @relation(fields: [categoryId], references: [id])
  warehouse    Warehouse?   @relation(fields: [warehouseId], references: [id])
  batches      ProductBatch[]
  invoiceItems InvoiceItem[]
  transactions InventoryTransaction[]
  priceHistory PriceHistory[]

  @@unique([name, warehouseId])
  @@unique([sku, warehouseId])
  @@map("products")
}

model PriceHistory {
  id           Int      @id @default(autoincrement())
  productId    Int      @map("product_id")
  costPrice    Float    @map("cost_price")
  sellingPrice Float    @map("selling_price")
  createdAt    DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@map("price_history")
}

model ProductBatch {
  id                Int      @id @default(autoincrement())
  productId         Int      @map("product_id")
  warehouseId       Int      @map("warehouse_id")
  quantity          Float
  remainingQuantity Float    @map("remaining_quantity")
  costPrice         Float    @map("cost_price")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  product         Product          @relation(fields: [productId], references: [id])
  warehouse       Warehouse        @relation(fields: [warehouseId], references: [id])
  saleAllocations SaleAllocation[]

  @@map("product_batches")
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  address   String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  invoices Invoice[]
  payments Payment[]
  returns  Return[]

  @@map("customers")
}

model Invoice {
  id          Int      @id @default(autoincrement())
  customerId  Int      @map("customer_id")
  userId      Int      @map("user_id")
  warehouseId Int      @map("warehouse_id")
  totalAmount Float    @map("total_amount")
  discount    Float    @default(0)
  tax         Float    @default(0)
  netAmount   Float    @map("net_amount")
  paidAmount  Float    @default(0) @map("paid_amount")
  returnedAmount Float   @default(0) @map("returned_amount")
  status      String   @default("unpaid") // 'paid' | 'partial' | 'unpaid'
  cancelled   Boolean  @default(false)
  paymentDueDate DateTime? @map("payment_due_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  customer     Customer      @relation(fields: [customerId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  warehouse    Warehouse     @relation(fields: [warehouseId], references: [id])
  items        InvoiceItem[]
  payments     Payment[]
  returns      Return[]

  @@map("invoices")
}

model InvoiceItem {
  id           Int      @id @default(autoincrement())
  invoiceId    Int      @map("invoice_id")
  productId    Int      @map("product_id")
  quantity     Float
  sellingPrice Float    @map("selling_price")
  costPrice    Float    @default(0) @map("cost_price")
  totalPrice   Float    @map("total_price")
  returnedQty  Float    @default(0) @map("returned_qty")

  invoice         Invoice          @relation(fields: [invoiceId], references: [id])
  product         Product          @relation(fields: [productId], references: [id])
  saleAllocations SaleAllocation[]

  @@map("invoice_items")
}

model SaleAllocation {
  id            Int   @id @default(autoincrement())
  invoiceItemId Int   @map("invoice_item_id")
  batchId       Int   @map("batch_id")
  quantity      Float

  invoiceItem  InvoiceItem  @relation(fields: [invoiceItemId], references: [id])
  batch        ProductBatch @relation(fields: [batchId], references: [id])

  @@map("sale_allocations")
}

model Payment {
  id         Int      @id @default(autoincrement())
  customerId Int      @map("customer_id")
  invoiceId  Int?     @map("invoice_id")
  userId     Int      @map("user_id")
  amount     Float
  method     String   @default("cash") // 'cash' | 'card' | 'transfer'
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id])
  invoice  Invoice? @relation(fields: [invoiceId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("payments")
}

model Return {
  id         Int      @id @default(autoincrement())
  invoiceId  Int      @map("invoice_id")
  customerId Int      @map("customer_id")
  userId     Int      @map("user_id")
  reason     String?
  totalValue Float    @map("total_value")
  createdAt  DateTime @default(now()) @map("created_at")

  invoice  Invoice  @relation(fields: [invoiceId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("returns")
}

model InventoryTransaction {
  id           Int      @id @default(autoincrement())
  productId    Int      @map("product_id")
  warehouseId  Int      @map("warehouse_id")
  userId       Int      @map("user_id")
  qtyChange    Float    @map("qty_change")
  type         String   // 'incoming' | 'outgoing' | 'return' | 'adjustment' | 'transfer'
  reason       String?
  referenceId  Int?     @map("reference_id") // ID of Invoice, Return, etc.
  costAtTime   Float?   @map("cost_at_time")
  sellingAtTime Float?  @map("selling_at_time")
  createdAt    DateTime @default(now()) @map("created_at")

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@map("inventory_transactions")
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("settings")
}

model Reminder {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  title       String
  description String?
  dueDate     DateTime @map("due_date")
  isCompleted Boolean  @default(false) @map("is_completed")
  type        String   @default("general") // 'restock' | 'payment' | 'general'
  referenceId Int?     @map("reference_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("reminders")
}
