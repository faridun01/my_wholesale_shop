// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id               Int       @id @default(autoincrement())
  username         String    @unique
  passwordHash     String    @map("password_hash")
  phone            String?   // Added for password recovery
  role             String    @default("SELLER") // 'ADMIN' | 'MANAGER' | 'SELLER'
  warehouseId      Int?      @map("warehouse_id")
  active           Boolean   @default(true)
  canCancelInvoices Boolean   @default(false) @map("can_cancel_invoices")
  canDeleteData    Boolean   @default(false) @map("can_delete_data")
  twoFactorEnabled Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret  String?   @map("two_factor_secret")
  twoFactorBackupCodes String[] @default([]) @map("two_factor_backup_codes")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id])
  invoices     Invoice[]
  payments     Payment[]
  returns      Return[]
  transactions InventoryTransaction[]
  reminders    Reminder[]
  expenses     Expense[]

  @@map("users")
}

model Warehouse {
  id          Int      @id @default(autoincrement())
  name        String
  address     String?
  city        String?
  phone       String?
  note        String?
  isDefault   Boolean  @default(false) @map("is_default")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users        User[]
  products     Product[]
  packagings   ProductPackaging[]
  batches      ProductBatch[]
  invoices     Invoice[]
  purchaseDocuments PurchaseDocument[]
  transactions InventoryTransaction[]
  expenses     Expense[]

  @@map("warehouses")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  products  Product[]

  @@map("categories")
}

model Product {
  id             Int      @id @default(autoincrement())
  categoryId     Int      @map("category_id")
  sku            String?
  name           String
  rawName        String?  @map("raw_name")
  brand          String?
  nameKey        String   @default("") @map("name_key")
  unit           String
  baseUnitName   String   @default("шт") @map("base_unit_name")
  purchaseCostPrice Decimal? @db.Decimal(12, 2) @map("purchase_cost_price")
  expensePercent Float   @default(0) @map("expense_percent")
  costPrice      Decimal  @db.Decimal(12, 2) @map("cost_price")
  sellingPrice   Decimal  @db.Decimal(12, 2) @map("selling_price")
  minStock       Float    @default(0) @map("min_stock")
  initialStock   Float    @default(0) @map("initial_stock")
  totalIncoming  Float    @default(0) @map("total_incoming")
  stock          Float    @default(0)
  photoUrl       String?  @map("photo_url")
  active         Boolean  @default(true)
  warehouseId    Int?     @map("warehouse_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  category     Category     @relation(fields: [categoryId], references: [id])
  warehouse    Warehouse?   @relation(fields: [warehouseId], references: [id])
  batches      ProductBatch[]
  invoiceItems InvoiceItem[]
  transactions InventoryTransaction[]
  priceHistory PriceHistory[]
  packagings   ProductPackaging[]
  purchaseItems PurchaseDocumentItem[]

  @@unique([warehouseId, nameKey])
  @@unique([name, warehouseId])
  @@unique([sku, warehouseId])
  @@map("products")
}

model ProductPackaging {
  id                  Int      @id @default(autoincrement())
  productId           Int      @map("product_id")
  warehouseId         Int?     @map("warehouse_id")
  packageName         String   @map("package_name")
  baseUnitName        String   @map("base_unit_name")
  unitsPerPackage     Int      @map("units_per_package")
  packageSellingPrice Decimal? @db.Decimal(12, 2) @map("package_selling_price")
  barcode             String?
  active              Boolean  @default(true)
  isDefault           Boolean  @default(false) @map("is_default")
  sortOrder           Int      @default(0) @map("sort_order")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  product   Product    @relation(fields: [productId], references: [id])
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])

  @@unique([productId, packageName, unitsPerPackage])
  @@unique([barcode, warehouseId])
  @@map("product_packagings")
}

model PriceHistory {
  id           Int      @id @default(autoincrement())
  productId    Int      @map("product_id")
  costPrice    Decimal  @db.Decimal(12, 2) @map("cost_price")
  sellingPrice Decimal  @db.Decimal(12, 2) @map("selling_price")
  createdAt    DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@map("price_history")
}

model ProductBatch {
  id                Int      @id @default(autoincrement())
  productId         Int      @map("product_id")
  warehouseId       Int      @map("warehouse_id")
  quantity          Float
  remainingQuantity Float    @map("remaining_quantity")
  purchaseCostPrice Decimal? @db.Decimal(12, 2) @map("purchase_cost_price")
  expensePercent    Float    @default(0) @map("expense_percent")
  costPrice         Decimal  @db.Decimal(12, 2) @map("cost_price")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  product         Product          @relation(fields: [productId], references: [id])
  warehouse       Warehouse        @relation(fields: [warehouseId], references: [id])
  saleAllocations SaleAllocation[]

  @@map("product_batches")
}

model Customer {
  id        Int      @id @default(autoincrement())
  customerType String @default("individual") @map("customer_type")
  name      String
  customerCategory String? @map("customer_category")
  companyName String? @map("company_name")
  contactName String? @map("contact_name")
  phone     String?
  country   String?
  region    String?
  address   String?
  city      String?
  notes     String?
  createdByUserId Int? @map("created_by_user_id")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  invoices Invoice[]
  payments Payment[]
  returns  Return[]

  @@map("customers")
}

model CompanyProfile {
  id          Int      @id @default(autoincrement())
  name        String
  country     String?
  region      String?
  city        String?
  addressLine String?  @map("address_line")
  phone       String?
  note        String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("company_profiles")
}

model Supplier {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String?
  address     String?
  city        String?
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  purchaseDocuments PurchaseDocument[]

  @@map("suppliers")
}

model PurchaseDocument {
  id             Int       @id @default(autoincrement())
  supplierId     Int?      @map("supplier_id")
  warehouseId    Int       @map("warehouse_id")
  sourceType     String    @default("pdf") @map("source_type")
  documentNumber String?   @map("document_number")
  documentDate   DateTime? @map("document_date")
  fileUrl        String?   @map("file_url")
  rawText        String?   @map("raw_text")
  status         String    @default("draft")
  importedAt     DateTime? @map("imported_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  supplier  Supplier?              @relation(fields: [supplierId], references: [id])
  warehouse Warehouse              @relation(fields: [warehouseId], references: [id])
  items     PurchaseDocumentItem[]

  @@map("purchase_documents")
}

model PurchaseDocumentItem {
  id                   Int      @id @default(autoincrement())
  purchaseDocumentId   Int      @map("purchase_document_id")
  matchedProductId     Int?     @map("matched_product_id")
  rawName              String   @map("raw_name")
  cleanName            String   @map("clean_name")
  brand                String?
  nameKey              String   @map("name_key")
  packageName          String?  @map("package_name")
  baseUnitName         String   @map("base_unit_name")
  unitsPerPackage      Int?     @map("units_per_package")
  packageQuantity      Float?   @map("package_quantity")
  extraUnitQuantity    Float    @default(0) @map("extra_unit_quantity")
  totalBaseUnits       Float    @map("total_base_units")
  expensePercent       Float    @default(0) @map("expense_percent")
  costPricePerBaseUnit Decimal? @db.Decimal(12, 2) @map("cost_price_per_base_unit")
  effectiveCostPricePerBaseUnit Decimal? @db.Decimal(12, 2) @map("effective_cost_price_per_base_unit")
  createdAt            DateTime @default(now()) @map("created_at")

  purchaseDocument PurchaseDocument @relation(fields: [purchaseDocumentId], references: [id])
  matchedProduct   Product?         @relation(fields: [matchedProductId], references: [id])

  @@map("purchase_document_items")
}

model Invoice {
  id          Int      @id @default(autoincrement())
  customerId  Int      @map("customer_id")
  userId      Int      @map("user_id")
  warehouseId Int      @map("warehouse_id")
  totalAmount Decimal  @db.Decimal(12, 2) @map("total_amount")
  discount    Float    @default(0)
  tax         Decimal  @default(0) @db.Decimal(12, 2)
  netAmount   Decimal  @db.Decimal(12, 2) @map("net_amount")
  paidAmount  Decimal  @default(0) @db.Decimal(12, 2) @map("paid_amount")
  returnedAmount Decimal @default(0) @db.Decimal(12, 2) @map("returned_amount")
  status      String   @default("unpaid") // 'paid' | 'partial' | 'unpaid'
  cancelled   Boolean  @default(false)
  paymentDueDate DateTime? @map("payment_due_date")
  companyNameSnapshot String? @map("company_name_snapshot")
  companyCountrySnapshot String? @map("company_country_snapshot")
  companyRegionSnapshot String? @map("company_region_snapshot")
  companyCitySnapshot String? @map("company_city_snapshot")
  companyAddressSnapshot String? @map("company_address_snapshot")
  customerNameSnapshot String? @map("customer_name_snapshot")
  customerPhoneSnapshot String? @map("customer_phone_snapshot")
  customerAddressSnapshot String? @map("customer_address_snapshot")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  customer     Customer      @relation(fields: [customerId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  warehouse    Warehouse     @relation(fields: [warehouseId], references: [id])
  items        InvoiceItem[]
  payments     Payment[]
  returns      Return[]

  @@map("invoices")
}

model InvoiceItem {
  id           Int      @id @default(autoincrement())
  invoiceId    Int      @map("invoice_id")
  productId    Int      @map("product_id")
  quantity     Float
  totalBaseUnits Float? @map("total_base_units")
  packageQuantity Float? @map("package_quantity")
  extraUnitQuantity Float @default(0) @map("extra_unit_quantity")
  packagingId  Int?     @map("packaging_id")
  packageNameSnapshot String? @map("package_name_snapshot")
  baseUnitNameSnapshot String? @map("base_unit_name_snapshot")
  unitsPerPackageSnapshot Int? @map("units_per_package_snapshot")
  productNameSnapshot String? @map("product_name_snapshot")
  rawNameSnapshot String? @map("raw_name_snapshot")
  brandSnapshot String? @map("brand_snapshot")
  sellingPrice Decimal  @db.Decimal(12, 2) @map("selling_price")
  costPrice    Decimal  @default(0) @db.Decimal(12, 2) @map("cost_price")
  totalPrice   Decimal  @db.Decimal(12, 2) @map("total_price")
  returnedQty  Float    @default(0) @map("returned_qty")

  invoice         Invoice          @relation(fields: [invoiceId], references: [id])
  product         Product          @relation(fields: [productId], references: [id])
  saleAllocations SaleAllocation[]

  @@map("invoice_items")
}

model SaleAllocation {
  id            Int   @id @default(autoincrement())
  invoiceItemId Int   @map("invoice_item_id")
  batchId       Int   @map("batch_id")
  quantity      Float

  invoiceItem  InvoiceItem  @relation(fields: [invoiceItemId], references: [id])
  batch        ProductBatch @relation(fields: [batchId], references: [id])

  @@map("sale_allocations")
}

model Payment {
  id         Int      @id @default(autoincrement())
  customerId Int      @map("customer_id")
  invoiceId  Int?     @map("invoice_id")
  userId     Int      @map("user_id")
  amount     Decimal  @db.Decimal(12, 2)
  method     String   @default("cash") // 'cash' | 'card' | 'transfer'
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id])
  invoice  Invoice? @relation(fields: [invoiceId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("payments")
}

model Expense {
  id          Int      @id @default(autoincrement())
  warehouseId Int      @map("warehouse_id")
  userId      Int      @map("user_id")
  category    String
  title       String
  amount      Decimal  @db.Decimal(12, 2)
  paidAmount  Decimal  @default(0) @db.Decimal(12, 2) @map("paid_amount")
  expenseDate DateTime @map("expense_date")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@map("expenses")
}

model Return {
  id         Int      @id @default(autoincrement())
  invoiceId  Int      @map("invoice_id")
  customerId Int      @map("customer_id")
  userId     Int      @map("user_id")
  reason     String?
  totalValue Decimal  @db.Decimal(12, 2) @map("total_value")
  createdAt  DateTime @default(now()) @map("created_at")

  invoice  Invoice  @relation(fields: [invoiceId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("returns")
}

model InventoryTransaction {
  id           Int      @id @default(autoincrement())
  productId    Int      @map("product_id")
  warehouseId  Int      @map("warehouse_id")
  userId       Int      @map("user_id")
  qtyChange    Float    @map("qty_change")
  type         String   // 'incoming' | 'outgoing' | 'return' | 'adjustment' | 'transfer'
  reason       String?
  referenceId  Int?     @map("reference_id") // ID of Invoice, Return, etc.
  costAtTime   Decimal? @db.Decimal(12, 2) @map("cost_at_time")
  sellingAtTime Decimal? @db.Decimal(12, 2) @map("selling_at_time")
  createdAt    DateTime @default(now()) @map("created_at")

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@map("inventory_transactions")
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("settings")
}

model Reminder {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  title       String
  description String?
  dueDate     DateTime @map("due_date")
  isCompleted Boolean  @default(false) @map("is_completed")
  type        String   @default("general") // 'restock' | 'payment' | 'general'
  referenceId Int?     @map("reference_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("reminders")
}
