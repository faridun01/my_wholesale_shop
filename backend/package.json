{
  "name": "inventory-backend",
  "version": "1.0.0",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p .",
    "start": "node dist/server.js",
    "lint": "tsc -p . --noEmit",
    "test": "npm run build && node dist/services/reminder.service.test.js && node dist/middlewares/auth.middleware.test.js",
    "reconcile:invoice-history": "tsx src/scripts/reconcile-invoice-history.ts",
    "reconcile:invoice-history:apply": "tsx src/scripts/reconcile-invoice-history.ts --apply",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:recategorize": "node prisma/recategorize-products.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@prisma/client": "^6.2.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/trusted-types": "^2.0.7",
    "prisma": "^6.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
